# Environment / secrets — NEVER commit these.
# Broadened to `.env.*` (any suffix) — the previous enumerated list
# silently missed variants such as .env.test, .env.ci and
# .env.enrich-websites (the FM-INC-2026-05-06-01 incident file, later
# added below). Committed example templates are explicitly re-allowed.
.env
.env.*
*.env
!.env.example
!.env.*.example
secrets.json
service-account*.json

# Enrichment / data pipeline logs
enrichment-log.txt
FILE_MANIFEST.txt

# Supabase local dev artifacts
supabase/.branches
supabase/.temp

# API key files - NEVER commit
.env.enrich-websites

# Source artifact archives — keep them out of main
*.tar.gz

# TypeScript incremental build cache — never commit
*.tsbuildinfo

# Compiled vite config (build artifact of vite.config.ts)
vite.config.js
vite.config.d.ts
