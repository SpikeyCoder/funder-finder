# .env.enrich-websites.example
#
# Preferred: inject keys at runtime (shell env or CI secret manager) before
# running the website-enrichment scripts under scripts/. Use a local
# `.env.enrich-websites` file only if needed, and keep it git-ignored.
# NEVER commit the real file -- the previous copy was committed and is being
# tracked as incident FM-INC-2026-05-06-01 (see
# compliance/SECURITY-INCIDENT-2026-05-06.md).
#
# Both keys MUST be rotated before being placed in this file -- the
# originals are reachable via git history and are considered compromised.

BRAVE_API_KEY=replace-me-with-a-rotated-brave-search-api-key
GOOGLE_API_KEY=replace-me-with-a-rotated-google-api-key
